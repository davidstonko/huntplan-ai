{
  "name": "RNBackgroundGeolocation",
  "cocoapods_version": ">= 1.10.0",
  "version": "5.0.5",
  "summary": "The most sophisticated cross-platform background location-tracking & geofencing module with battery-conscious motion-detection intelligence",
  "description": "Cross-platform background geolocation module for React Native with\nbattery-saving circular stationary-region monitoring and stop detection.",
  "homepage": "https://www.transistorsoft.com/shop/products/react-native-background-geolocation",
  "license": "MIT",
  "authors": "Chris Scott <chris@transistorsoft.com>",
  "source": {
    "git": "https://github.com/transistorsoft/react-native-background-geolocation.git",
    "tag": "5.0.5"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "static_framework": true,
  "source_files": "ios/RNBackgroundGeolocation/*.{h,m,mm}",
  "preserve_paths": [
    "docs",
    "CHANGELOG.md",
    "LICENSE",
    "package.json",
    "RNBackgroundGeolocation.ios.js"
  ],
  "dependencies": {
    "CocoaLumberjack": [
      "~> 3.8.5"
    ],
    "TSLocationManager": [
      "~> 4.0.10"
    ],
    "React-Core": [],
    "RCT-Folly": [
      "2024.01.01.00"
    ],
    "glog": [],
    "React-RCTFabric": [],
    "ReactCodegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "DoubleConversion": [],
    "hermes-engine": []
  },
  "libraries": [
    "sqlite3",
    "z",
    "stdc++"
  ],
  "resource_bundles": {
    "TSLocationManagerPrivacy": [
      "ios/Resources/PrivacyInfo.xcprivacy"
    ]
  },
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32",
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32"
  }
}
